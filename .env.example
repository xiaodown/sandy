
#########################
# Discord API key
#########################

# Primary key (prod server)
DISCORD_API_KEY="insert_discord_api_key_here"

# Test key (dev server) — used automatically with `python -m sandy --test`
DISCORD_API_KEY_TEST="insert_test_discord_api_key_here"

########################
# Databases
########################

# Database directory
# This is where the three databases live:
# 
# server database - a lightweight mapping of server names and ids with 
#    user names, ids, and nicknames foreign keyd so we can look up without
#    hitting the discord API
# recall database - a log of all messages that the bot has ever seen in 
#    any channels that she's in, along with meta information including
#    author, tags, and summary if the message is long
# 
# Primary database directory (prod mode)
DB_DIR="data/prod/"

# Test database directory
# `python -m sandy --test` swaps DB_DIR to this value before the bot imports.
TEST_DB_DIR="data/test/"

# Names of the actual database files
SERVER_DB_NAME="server.db"
RECALL_DB_NAME="recall.db"


#########################
# AI models
#########################

# This is a constant work in progress.  I am working on finding more appropriate models
# while attempting to balance against my vram constraints.

# "big" models
#    This is the models that need to be more capable, think deeper, and understand more
# 
# Brain - the main model for personality and casual conversation
# Bouncer - the model that handles pre-conversation tasks, like deciding if the bot should
#    respond or use a tool.
#
BRAIN_MODEL="hf.co/unsloth/Mistral-Small-3.2-24B-Instruct-2506-GGUF:UD-Q4_K_XL"
BOUNCER_MODEL="llama3.1:8b"

# "small" models
#    These can now share a smaller instruct model without the old VRAM thrash problem.
#
# Tagger - provides tags to send to the chat log database
# Summarizer - provides summaries of chat messages sent to the chat log database, if length
#    exceeds SUMMARIZE_THRESHOLD (below)
# Vision - allows bot to "see" posted images in chat using a dedicated vision model
# Vision router - cheap caption model used before the bouncer decides whether
#    Sandy should reply. This can be a tiny multimodal model.
# Embed - the model used to generate RAG vectors to store in chromadb for future
#    retrieval
#
TAGGER_MODEL="llama3.1:8b"
SUMMARIZER_MODEL="llama3.1:8b"
VISION_MODEL="llama3.2-vision:11b"
VISION_ROUTER_MODEL="qwen3.5:0.8b"
EMBED_MODEL="mxbai-embed-large"


######################
# AI Settings
######################

# Temperatures
#    1.0 = neutral, higher = more creative/weird. Start at 1.1, tune from there.
#
# Brain temperature should probably be somewhere around 1, or else she starts sounding either
#    really boring and robotic (low) or completely unhinged and divorced from reality (high)
#
BRAIN_TEMPERATURE=0.8

# Other temperatures: should be low or zero to make outputs more deterministic and trustworthy
#
BOUNCER_TEMPERATURE=0.1
TAGGER_TEMPERATURE=0.1
SUMMARIZER_TEMPERATURE=0.1

# Token settings:
#
# Max tokens per response
#    Discord hard limit is ~2000 chars
#    Lower keeps Sandy concise.
#
BRAIN_NUM_PREDICT=384

# Context window. 
#    Ollama defaults to 2048 regardless of model capability, so we need to set explicitly
#
BRAIN_NUM_CTX=16384
BOUNCER_NUM_CTX=8192
TAGGER_NUM_CTX=8192
SUMMARIZER_NUM_CTX=8192
VISION_NUM_CTX=4096
VISION_NUM_PREDICT=224
VISION_TEMPERATURE=0.3
VISION_ROUTER_NUM_CTX=2048
VISION_ROUTER_NUM_PREDICT=48
VISION_ROUTER_TEMPERATURE=0.1


#####################
# Misc settings
#####################

# Pre-Warm model
#    Set these if you want the bot to put a model into vram when it loads
#    If you do want to warm a model, the bouncer model probably makes most sense
#
PREWARM_MODEL="True"
PREWARM_MODEL_NAME="${BRAIN_MODEL}"
PREWARM_NUM_CTX=16384

# Ollama keep-alive
#    How long ollama keeps models loaded in VRAM after the last request.
#    Keep models resident if Sandy is the main GPU workload. In local testing,
#    unloading after 30m freed VRAM but did not materially reduce idle watts,
#    and it made the next reply noticeably slower.
#
OLLAMA_KEEP_ALIVE=1h
    
# Summarizing threshold
#    Messages longer than this many characters will additionally be summarized
#    before they are sent to the chat logging system
#
SUMMARIZE_THRESHOLD=450

# SearXNG
#    Used for the bot to be able to look things up on the internet.
#    SearXNG is run as a docker container - see searxng/ for a 
#    docker-compose file and configs.
#
SEARXNG_HOST=127.0.0.1
SEARXNG_PORT=8888

# Local observability API
#    Read-only HTTP API for dashboards / local inspection.
#    Bind to localhost by default so this does not become an accidental
#    network-facing service.
#
SANDY_API_ENABLED=true
SANDY_API_HOST=127.0.0.1
SANDY_API_PORT=8765


#########################
# Voice runtime
#########################

# Voice admin / capture / reply behavior
VOICE_CAPTURE_DIR="data/prod/voice_captures"
VOICE_PREROLL_MS=250
VOICE_STITCH_GAP_SECONDS=1.0
VOICE_STITCH_RELEASE_SECONDS=1.35
VOICE_FORCE_RELEASE_SECONDS=3.25
VOICE_HISTORY_MAXLEN=12
VOICE_IDLE_AUTO_LEAVE_SECONDS=300
VOICE_REPLY_MAX_WORDS=32
VOICE_REPLY_MAX_CHARS=220
VOICE_REPLY_MAX_SENTENCES=2

# Speech-to-text
VOICE_STT_MODEL="base.en"
VOICE_STT_DEVICE="cuda"
VOICE_STT_COMPUTE_TYPE="float16"
VOICE_STT_LANGUAGE="en"

# Voice brain
VOICE_BRAIN_NUM_PREDICT=80

# TTS client settings used by Sandy Prime when talking to the local service
VOICE_TTS_SERVICE_URL="http://127.0.0.1:8777"
VOICE_TTS_SERVICE_TIMEOUT_SECONDS=180
VOICE_TTS_LANGUAGE="English"
# Optional style / instruct text passed through to the service.
# Leave blank when clone mode is carrying the identity already.
VOICE_TTS_INSTRUCT=""


#########################
# TTS service
#########################

# These are read by `python -m tts_service`.
TTS_SERVICE_MODEL="Qwen/Qwen3-TTS-12Hz-1.7B-Base"
TTS_SERVICE_LANGUAGE="English"
TTS_SERVICE_CLONE_REF_AUDIO="/home/xiaodown/code/sandy/tts_service/assets/clone_reference.wav"
TTS_SERVICE_CLONE_REF_TEXT="goodnight robst. sleep well, dream of snacks and revenge."
TTS_SERVICE_CLONE_XVECTOR_ONLY=true
TTS_SERVICE_DEVICE="cuda"
TTS_SERVICE_DTYPE="bfloat16"
TTS_SERVICE_ATTN_IMPLEMENTATION="sdpa"
TTS_SERVICE_MAX_SEQ_LEN=2048
TTS_SERVICE_MAX_NEW_TOKENS=512
TTS_SERVICE_MIN_NEW_TOKENS=2
TTS_SERVICE_DO_SAMPLE=false
TTS_SERVICE_TEMPERATURE=0.9
TTS_SERVICE_TOP_K=50
TTS_SERVICE_TOP_P=1.0
TTS_SERVICE_REPETITION_PENALTY=1.05
TTS_SERVICE_NON_STREAMING_MODE=false
TTS_SERVICE_MAX_AUDIO_SECONDS=20
TTS_SERVICE_WARMUP_TEXT="hello there"
